{
  "name": "oxhq/cachelet-request",
  "description": "Request and response caching integration for Cachelet.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "OxHQ",
      "homepage": "https://github.com/oxhq"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/auth": "^12.0|^13.0",
    "illuminate/http": "^12.0|^13.0",
    "illuminate/routing": "^12.0|^13.0",
    "oxhq/cachelet-core": "^0.1"
  },
  "autoload": {
    "psr-4": {
      "Oxhq\\Cachelet\\Request\\": "src/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    },
    "laravel": {
      "providers": [
        "Oxhq\\Cachelet\\Request\\Providers\\CacheletRequestServiceProvider"
      ],
      "aliases": {
        "CacheletRequest": "Oxhq\\Cachelet\\Request\\Facades\\CacheletRequest"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "homepage": "https://github.com/oxhq/cachelet",
  "keywords": [
    "laravel",
    "cache",
    "swr",
    "invalidation",
    "middleware",
    "response-cache"
  ],
  "support": {
    "issues": "https://github.com/oxhq/cachelet/issues",
    "source": "https://github.com/oxhq/cachelet/tree/main/packages/cachelet-request"
  }
}
